{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(npm test *)",
      "Bash(pytest *)",
      "Bash(godot --headless --quit)",
      "Bash(bash .claude/hooks/*.sh)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase -i *)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./credentials*)",
      "Read(./**/*secret*)",
      "Bash(cat .env*)",
      "Bash(cat credentials*)",
      "Bash(cat *secret*)"
    ]
  }
}
